# Database (Neon Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# LLM Providers
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.6-terra
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=4
GROQ_TIMEOUT_SECONDS=6
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=300
LLM_FIRST_INTENT_ENABLED=true

# Hybrid live product verification
LIVE_PRODUCT_VALIDATION_ENABLED=true
LIVE_PRODUCT_TIMEOUT_SECONDS=2
LIVE_PRODUCT_CONCURRENCY=16
LIVE_PRODUCT_SHORTLIST_SIZE=32
PRODUCT_CACHE_REFRESH_INTERVAL_MINUTES=120

# Browser extension MVP (Groq keys stay here; never place one in extension/)
EXTENSION_ALLOWED_DOMAINS=outfitters.com.pk,www.outfitters.com.pk
EXTENSION_ALLOWED_ORIGINS=
EXTENSION_CATALOG_MAX_PRODUCTS=5000
EXTENSION_CATALOG_CACHE_TTL_MINUTES=15
EXTENSION_REQUEST_TIMEOUT_SECONDS=25
EXTENSION_RANK_CANDIDATE_LIMIT=40
EXTENSION_RESULT_LIMIT=40

# Cache Store (Railway Redis)
REDIS_URL=redis://default:password@host:port/0

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=change_me_to_a_random_secret

# Environment
ENVIRONMENT=development

# Session store backend (memory or redis)
SESSION_STORE_BACKEND=redis

# Log level
LOG_LEVEL=info
